{
  "name": "helix-code",
  "version": "1.0.0-beta",
  "private": true,
  "description": "A lightweight, permission-first desktop coding agent.",
  "main": "dist/main/main/index.js",
  "scripts": {
    "predev": "tsc -p tsconfig.main.json",
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && set ELECTRON_RUN_AS_NODE=&& set VITE_DEV_SERVER_URL=http://localhost:5173&& electron .\"",
    "build": "tsc -p tsconfig.main.json && vite build && electron-builder",
    "typecheck": "tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.renderer.json"
  },
  "build": {
    "appId": "com.neonatro.helixcode",
    "productName": "Helix Code",
    "directories": { "output": "release" },
    "extraResources": ["app_logo.png"],
    "files": ["dist/**", "package.json"],
    "win": { "target": ["portable", "nsis"], "icon": "app_logo.png" },
    "mac": { "target": ["dmg"] },
    "linux": { "target": ["AppImage"] }
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^36.0.0",
    "electron-builder": "^26.0.12",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "wait-on": "^8.0.1"
  }
}
